{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/Continuum/schemas/harness-contribution.schema.json",
  "title": "Continuum harness contribution manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "kind", "source", "contributions"],
  "properties": {
    "$schema": {"const": "../schemas/harness-contribution.schema.json"},
    "schema_version": {"const": 1},
    "kind": {"const": "continuum.harness-contribution-manifest"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit_sha", "authority_paths"],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "authority_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/repositoryPath"}
        }
      }
    },
    "contributions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/contribution"}
    }
  },
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*//)(?!.*\\\\).+$"
    },
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$"}
    },
    "contribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "source_paths",
        "classification",
        "maturity",
        "target_layer",
        "capabilities",
        "rationale"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "title": {"type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$"},
        "source_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/repositoryPath"}
        },
        "classification": {
          "enum": ["portable_harness", "repo_skill", "domain_specific"]
        },
        "maturity": {
          "enum": ["merged", "experimental", "deprecated"]
        },
        "target_layer": {
          "enum": ["continuum_harness", "continuum_skill", "reference_only", "reject"]
        },
        "capabilities": {"$ref": "#/$defs/nonEmptyUniqueStrings"},
        "rationale": {"type": "string", "minLength": 1, "pattern": "^\\S(?:.*\\S)?$"}
      }
    }
  }
}
