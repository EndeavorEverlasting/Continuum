{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/EndeavorEverlasting/Continuum/schemas/repository.schema.json",
  "title": "Continuum repository contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "harness_version", "repository", "branch_policy", "completion_proof", "commands", "boundaries", "evidence"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": 1},
    "harness_version": {"type": "string", "minLength": 1},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "default_branch"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "default_branch": {"type": "string", "minLength": 1}
      }
    },
    "branch_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonical_base", "stacked_pull_requests", "merge_green_predecessors_before_next_sprint", "require_clean_base", "require_current_canonical_base"],
      "properties": {
        "canonical_base": {"type": "string", "minLength": 1},
        "stacked_pull_requests": {"enum": ["forbidden", "explicit_only", "allowed"]},
        "merge_green_predecessors_before_next_sprint": {"type": "boolean"},
        "require_clean_base": {"type": "boolean"},
        "require_current_canonical_base": {"type": "boolean"}
      }
    },
    "completion_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "repository", "workflow", "event", "required_conclusion"],
      "properties": {
        "provider": {"const": "github_actions"},
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "workflow": {"type": "string", "minLength": 1},
        "event": {"const": "push"},
        "required_conclusion": {"const": "success"}
      }
    },
    "commands": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protected_paths", "forbidden_operations"],
      "properties": {
        "protected_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "forbidden_operations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    }
  }
}
